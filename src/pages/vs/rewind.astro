---
// src/pages/vs/rewind.astro
//
// SEO: Rewind AI alternative landing page.
// Rewind the standalone Mac app was shut down in December 2025 after Meta
// acquired Limitless (Rewind's parent). This page captures the still-high
// "rewind alternative" search volume while being honest about the shutdown.
// Skilly is positioned as an alternative for ACTIVE tutoring, not for the
// passive personal-memory use case Rewind originally solved. For that use
// case we point people to Screenpipe (the open-source successor).

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { DOWNLOAD_URL } from '../../data/config.ts';

const title = 'Skilly vs Rewind — Rewind is dead, here is what comes next';
const description =
  'Meta acquired Limitless in December 2025 and shut down the original Rewind AI Mac app. If you are looking for a Rewind alternative, this page maps your options — active tutoring (Skilly) vs passive personal memory (Screenpipe).';

const comparisonRows = [
  { feature: 'Status (2026)', skilly: 'Active — in beta, shipping', rewind: 'Shut down. Meta acquired Limitless Dec 2025; rewind.ai is dark.' },
  { feature: 'Primary use case', skilly: 'Live tutor — ask out loud, get a voice answer, cursor moves to the exact UI element', rewind: 'Was: personal memory — continuous screen + audio recording, searchable history' },
  { feature: 'Capture model', skilly: 'Voice-gated: screen captured only when you press push-to-talk or speak', rewind: 'Was: always-on continuous recording of screen + audio + browser history' },
  { feature: 'When you use it', skilly: 'The moment you are stuck in an app', rewind: 'Was: after the fact, when you needed to recall something' },
  { feature: 'Output', skilly: 'Voice answer + cursor moves to the exact UI element + live transcript', rewind: 'Was: searchable timeline, summaries, meeting transcripts' },
  { feature: 'Storage footprint', skilly: 'Minimal — no continuous recording, no local video index', rewind: 'Was: significant — weeks to months of screen recording stored locally' },
  { feature: 'Platform', skilly: 'Native macOS menu bar app (14.0+)', rewind: 'Was: macOS + iOS' },
  { feature: 'Open source', skilly: 'Yes — Apache-2.0 (fork of farzaa/clicky, MIT)', rewind: 'Was: proprietary' },
  { feature: 'Pricing', skilly: '15 minutes free, then $19/month for 3 hours of tutoring', rewind: 'n/a — app is no longer available' },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: 'https://tryskilly.app/vs/rewind',
  about: [
    { '@type': 'SoftwareApplication', name: 'Skilly', applicationCategory: 'EducationalApplication', operatingSystem: 'macOS 14.0+' },
  ],
};
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  </Fragment>
  <Nav />
  <main class="overflow-x-clip">
    <section class="relative max-w-site mx-auto px-6 pt-32 lg:pt-40 pb-8">
      <div class="max-w-[820px] mx-auto text-center">
        <p class="text-sm font-medium text-amber-700 tracking-wide uppercase mb-4">Honest comparison</p>
        <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-bold leading-[1.1] tracking-tight text-gray-900 mb-6">
          Skilly <span class="text-gray-400">vs</span> Rewind
        </h1>
        <p class="text-lg lg:text-xl leading-relaxed text-gray-600 mb-6 max-w-[680px] mx-auto">
          Heads up — Rewind AI is no longer a standalone product. Meta acquired Limitless (Rewind&apos;s parent)
          in December 2025 and the Mac app was shut down. If you are looking for a Rewind alternative, the
          answer depends on which part of Rewind you actually want.
        </p>
      </div>
    </section>

    <!-- Status banner -->
    <section class="max-w-site mx-auto px-6 pb-10">
      <div class="max-w-[820px] mx-auto bg-red-50/60 border border-red-200 rounded-xl p-5 flex items-start gap-3">
        <span class="inline-block w-2 h-2 rounded-full bg-red-500 mt-2 shrink-0" aria-hidden="true"></span>
        <div>
          <p class="font-semibold text-gray-900 text-[15px] mb-1">Rewind status: discontinued (Dec 2025)</p>
          <p class="text-gray-600 text-[14px] leading-relaxed">
            Meta&apos;s acquisition folded Limitless into its wearables team. rewind.ai is offline.
            Existing Rewind data is not portable to Meta&apos;s products. If you are here for a replacement, see below.
          </p>
        </div>
      </div>
    </section>

    <!-- Picking the right alternative -->
    <section class="max-w-site mx-auto px-6 pb-12">
      <div class="max-w-[960px] mx-auto grid md:grid-cols-2 gap-5">
        <div class="bg-white border border-gray-200 rounded-xl p-7 shadow-sm">
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-block w-2.5 h-2.5 rounded-full bg-amber-500"></span>
            <span class="font-semibold text-gray-900">Pick Skilly if</span>
          </div>
          <p class="text-gray-600 leading-relaxed text-[15px]">
            You liked that Rewind <strong class="text-gray-900">understood what was on your screen</strong> —
            and what you actually want is a <strong class="text-gray-900">tutor</strong> that answers questions
            about the app you are in, not a recording of everything you have ever done.
            Voice in, voice out, cursor moves to the right button.
          </p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-7 shadow-sm">
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-block w-2.5 h-2.5 rounded-full bg-gray-400"></span>
            <span class="font-semibold text-gray-900">Pick Screenpipe if</span>
          </div>
          <p class="text-gray-600 leading-relaxed text-[15px]">
            You want the <strong class="text-gray-900">personal-memory</strong> feature specifically —
            continuous screen + audio recording you can search later.
            <a href="https://github.com/mediar-ai/screenpipe" target="_blank" rel="noopener" class="text-amber-700 underline decoration-amber-300 underline-offset-2 hover:decoration-amber-500">Screenpipe</a>
            is the open-source successor most Rewind refugees have moved to.
            This is not what Skilly does — we would rather send you there honestly than sell you the wrong tool.
          </p>
        </div>
      </div>
    </section>

    <!-- Historical comparison -->
    <section class="max-w-site mx-auto px-6 pb-16">
      <div class="max-w-[960px] mx-auto">
        <h2 class="text-2xl lg:text-3xl font-semibold text-gray-900 mb-2 text-center">Feature by feature</h2>
        <p class="text-center text-gray-500 text-sm mb-6">Rewind column reflects the product&apos;s state before the December 2025 shutdown.</p>
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <table class="w-full text-left text-[15px]">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-5 py-3.5 font-semibold text-gray-700 w-[28%]">Feature</th>
                <th class="px-5 py-3.5 font-semibold text-amber-700">Skilly</th>
                <th class="px-5 py-3.5 font-semibold text-gray-600">Rewind (discontinued)</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr class="border-b border-gray-100 last:border-b-0 align-top">
                  <td class="px-5 py-4 font-medium text-gray-900">{row.feature}</td>
                  <td class="px-5 py-4 text-gray-700 leading-relaxed">{row.skilly}</td>
                  <td class="px-5 py-4 text-gray-600 leading-relaxed">{row.rewind}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="max-w-site mx-auto px-6 pb-16">
      <div class="max-w-[680px] mx-auto text-center bg-gradient-to-br from-amber-50 to-white border border-amber-200/60 rounded-2xl p-10">
        <h2 class="text-2xl lg:text-3xl font-semibold text-gray-900 mb-3">Want to try Skilly?</h2>
        <p class="text-gray-600 mb-6">15 minutes free, no card. Apache-2.0 open source, fork of Farza&apos;s Clicky (MIT).</p>
        <a
          href={DOWNLOAD_URL}
          data-ph-event="web_cta_download_clicked"
          data-ph-prop-location="vs_rewind"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 active:scale-[0.98] text-gray-950 shadow-md hover:shadow-lg rounded-lg px-8 py-3.5 text-[17px] font-semibold transition-all"
        >
          Download Skilly
        </a>
      </div>
    </section>

    <section class="max-w-site mx-auto px-6 pb-20">
      <div class="max-w-[960px] mx-auto">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">More comparisons</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <a href="/vs/cluely" class="block border border-gray-200 rounded-lg px-5 py-4 hover:border-amber-400 hover:bg-amber-50/40 transition-colors">
            <p class="font-medium text-gray-900">Skilly vs Cluely</p>
            <p class="text-sm text-gray-500 mt-1">Tutor vs meeting coach</p>
          </a>
          <a href="/vs/raycast-ai" class="block border border-gray-200 rounded-lg px-5 py-4 hover:border-amber-400 hover:bg-amber-50/40 transition-colors">
            <p class="font-medium text-gray-900">Skilly vs Raycast AI</p>
            <p class="text-sm text-gray-500 mt-1">Voice + screen vs command bar</p>
          </a>
          <a href="/vs/gemini-live" class="block border border-gray-200 rounded-lg px-5 py-4 hover:border-amber-400 hover:bg-amber-50/40 transition-colors">
            <p class="font-medium text-gray-900">Skilly vs Gemini Live</p>
            <p class="text-sm text-gray-500 mt-1">Native Mac app vs browser tab</p>
          </a>
          <a href="/vs/clicky" class="block border border-gray-200 rounded-lg px-5 py-4 hover:border-amber-400 hover:bg-amber-50/40 transition-colors">
            <p class="font-medium text-gray-900">Skilly vs Clicky (parent fork)</p>
            <p class="text-sm text-gray-500 mt-1">What we added on top</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
