---
// src/components/FAQ.astro
//
// The first 3 questions are expanded by default. Order is in faqs.ts and
// was chosen per page-cro objection-handling priority: regret aversion first,
// trust second, price third.
import { faqs } from '../data/faqs.ts';
const EXPANDED_BY_DEFAULT = 3;
---
<section id="faq" class="relative py-24 lg:py-32 px-6">
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, #E5E5E0, transparent);"
  ></div>

  <div class="max-w-[720px] mx-auto">
    <div class="text-center mb-14 lg:mb-16">
      <span class="text-[13px] font-semibold text-amber-600 tracking-[1.5px] uppercase">FAQ</span>
      <h2 data-reveal class="reveal text-3xl sm:text-4xl lg:text-[44px] font-bold tracking-tight mt-3 text-gray-900">
        Questions, answered.
      </h2>
    </div>

    <div class="flex flex-col gap-3">
      {faqs.map((faq, i) => {
        const isDefaultOpen = i < EXPANDED_BY_DEFAULT;
        const delay = Math.min(i + 1, 5);
        return (
          <details
            data-reveal
            open={isDefaultOpen}
            class={`reveal reveal-delay-${delay} group bg-white rounded-2xl border border-gray-200 hover:border-amber-500/40 shadow-sm hover:shadow-md transition-all`}
          >
            <summary
              class="list-none cursor-pointer px-6 py-5 flex items-center justify-between gap-4 text-[17px] font-semibold text-gray-900"
            >
              <span>{faq.question}</span>
              <svg
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
                class="shrink-0 text-amber-500 transition-transform duration-300 group-open:rotate-45"
              >
                <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
              </svg>
            </summary>
            <div class="px-6 pb-6 pt-0 text-[15px] leading-relaxed text-gray-600">
              {faq.answer}
            </div>
          </details>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Hide default Safari details marker */
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
