---
<section id="skills" class="relative py-24 lg:py-32 px-6">
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, #E5E5E0, transparent);"
  ></div>

  <div class="max-w-site mx-auto">
    <div class="max-w-[640px] mx-auto text-center mb-16 lg:mb-20">
      <span class="text-[13px] font-semibold text-amber-600 tracking-[1.5px] uppercase">Skills</span>
      <h2 data-reveal class="reveal text-3xl sm:text-4xl lg:text-[44px] font-bold tracking-tight leading-[1.15] mt-3 mb-5 text-gray-900">
        <span class="block">Works in any app.</span>
        <span class="block text-amber-600 mt-2 sm:mt-3">Skills make it way better.</span>
      </h2>
      <p data-reveal class="reveal reveal-delay-1 text-[17px] leading-relaxed text-gray-600 mb-5">
        Skills are optional add-ons that give Skilly two superpowers for specific apps.
      </p>
      <ul data-reveal class="reveal reveal-delay-2 inline-block text-left space-y-3 max-w-[560px]">
        <li class="flex gap-3 items-start">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" aria-hidden="true">
            <path d="M5 10l4 4 6-8" />
          </svg>
          <span class="text-[15px] leading-relaxed text-gray-600">
            <strong class="font-semibold text-gray-900">Always up-to-date knowledge</strong> — straight from each app's official docs (beyond the AI's training cutoff), so answers stay accurate and current.
          </span>
        </li>
        <li class="flex gap-3 items-start">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" aria-hidden="true">
            <path d="M5 10l4 4 6-8" />
          </svg>
          <span class="text-[15px] leading-relaxed text-gray-600">
            <strong class="font-semibold text-gray-900">Guided courses</strong> — turn learning into step-by-step lessons with progress tracking. Skilly can coach you from beginner to pro, check what you're doing, and move to the next lesson when you're ready.
          </span>
        </li>
      </ul>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {skills.map((skill, i) => {
        const isAvailable = skill.status === 'available';
        const isComingSoon = skill.status === 'coming_soon';
        const isRequest = skill.status === 'request';
        const delay = Math.min(i + 1, 5);

        const baseClasses = `reveal reveal-delay-${delay} relative rounded-2xl p-7 transition-all duration-300`;

        const stateClasses = isAvailable
          ? 'bg-white border border-gray-200 shadow-sm hover:border-amber-500/50 hover:shadow-md hover:-translate-y-1'
          : isComingSoon
            ? 'bg-gray-100 border border-gray-200 hover:border-gray-300'
            : 'bg-amber-50/40 border-2 border-dashed border-amber-500/45 hover:border-amber-500/70 hover:-translate-y-1';

        const wrapperClass = `${baseClasses} ${stateClasses}`;

        const pillClasses = isAvailable
          ? 'bg-green-500/10 border border-green-500/25 text-green-700'
          : isComingSoon
            ? 'bg-gray-200 border border-gray-300 text-gray-600'
            : 'bg-amber-500/15 border border-amber-500/30 text-amber-700';

        const Tag = isRequest ? 'a' : 'div';
        const tagProps = isRequest
          ? {
              href: skill.href,
              'data-ph-event': 'web_skill_request_clicked',
              class: `${wrapperClass} block group`,
            }
          : { class: wrapperClass };

        const brand = isAvailable ? brandLogos[skill.name] : null;

        return (
          <Tag data-reveal {...tagProps}>
            <div class="flex items-start justify-between mb-5">
              {brand ? (
                <div
                  class="w-12 h-12 rounded-xl bg-gray-100 border border-gray-200 flex items-center justify-center transition-colors"
                  style={`color: ${brand.color}`}
                  aria-hidden="true"
                >
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                    <path d={brand.path} />
                  </svg>
                </div>
              ) : (
                <span class={`inline-flex items-center gap-1.5 text-[10px] font-mono font-semibold tracking-wider uppercase px-2.5 py-1 rounded ${pillClasses}`}>
                  {statusLabel[skill.status]}
                </span>
              )}
              {brand && (
                <span class={`inline-flex items-center gap-1.5 text-[10px] font-mono font-semibold tracking-wider uppercase px-2.5 py-1 rounded ${pillClasses}`}>
                  <span class="block w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse-soft" aria-hidden="true"></span>
                  {statusLabel[skill.status]}
                </span>
              )}
              {isRequest && (
                <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-600 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true">
                  <path d="M4 12L12 4M12 4H5M12 4V11"/>
                </svg>
              )}
            </div>

            <h3 class={`text-xl lg:text-2xl font-bold tracking-tight ${isComingSoon ? 'text-gray-600' : 'text-gray-900'}`}>
              {skill.name}
            </h3>

            {isAvailable && skill.description && (
              <p class="text-[14px] text-gray-600 mt-1.5 leading-relaxed">{skill.description}</p>
            )}

            {isRequest && (
              <p class="text-[14px] text-gray-600 mt-1.5 leading-relaxed">
                Tell us which app you'd learn with Skilly.
              </p>
            )}
          </Tag>
        );
      })}
    </div>

    <p class="text-center text-[14px] text-gray-500 mt-12 max-w-[560px] mx-auto leading-relaxed">
      Five skills ship as examples — a skill builder is coming. Want to build your own?
      {' '}
      <a href="mailto:hello@tryskilly.app" class="text-amber-600 hover:text-amber-700 underline underline-offset-2">Get in touch</a>
      {' '}
      — we're exploring a creator program.
    </p>

    <!-- Skill request form -->
    <div id="skill-request" class="max-w-[480px] mx-auto mt-16 scroll-mt-24">
      <div data-skill-request-wrapper class="bg-white rounded-[20px] border border-gray-200 shadow-sm p-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-1">Request a skill</h3>
        <p class="text-sm text-gray-600 mb-6 leading-relaxed">Tell us which app you'd learn with Skilly. We read every request.</p>

        <form data-skill-request-form>
          <div class="flex flex-col gap-4 mb-4">
            <div>
              <label class="text-sm font-medium text-gray-700 block mb-1.5" for="sr-app">App name</label>
              <input
                id="sr-app"
                type="text"
                name="appName"
                placeholder="e.g. Unity, Houdini, Cinema 4D..."
                required
                class="w-full px-4 py-3 rounded-lg text-[15px] bg-white border border-gray-300 text-gray-900 placeholder-gray-400 outline-none focus:border-amber-500 transition-colors"
              />
            </div>
            <div>
              <label class="text-sm font-medium text-gray-700 block mb-1.5" for="sr-email">Your email</label>
              <input
                id="sr-email"
                type="email"
                name="email"
                placeholder="you@example.com"
                required
                class="w-full px-4 py-3 rounded-lg text-[15px] bg-white border border-gray-300 text-gray-900 placeholder-gray-400 outline-none focus:border-amber-500 transition-colors"
              />
            </div>
            <div>
              <label class="text-sm font-medium text-gray-700 block mb-1.5" for="sr-message">What would you learn? <span class="text-gray-500 font-normal">(optional)</span></label>
              <textarea
                id="sr-message"
                name="message"
                rows="2"
                placeholder="e.g. character rigging, 3D environments..."
                class="w-full px-4 py-3 rounded-lg text-[15px] bg-white border border-gray-300 text-gray-900 placeholder-gray-400 outline-none focus:border-amber-500 transition-colors resize-none"
              ></textarea>
            </div>
          </div>
          <button
            type="submit"
            disabled
            class="w-full bg-amber-500 hover:bg-amber-600 text-gray-950 shadow-sm hover:shadow-md rounded-lg px-6 py-3 text-[15px] font-semibold transition-all opacity-50 cursor-not-allowed"
          >
            Submit request
          </button>
          <p class="text-xs text-gray-500 mt-2.5 text-center">We'll email you if this skill becomes available.</p>
        </form>
      </div>

      <div data-skill-request-success hidden class="bg-white rounded-[20px] border border-amber-500/30 shadow-sm p-10 text-center">
        <div class="w-14 h-14 rounded-full bg-amber-500/10 border-2 border-amber-500/25 flex items-center justify-center mx-auto mb-5">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12l5 5L20 7" />
          </svg>
        </div>
        <h3 class="text-[22px] font-semibold text-gray-900 mb-2">Request received!</h3>
        <p class="text-[15px] text-gray-600 leading-relaxed">
          We'll notify you when a <span data-success-app class="text-amber-700 font-medium"></span> skill is available.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import '../scripts/skill-request.ts';
</script>
