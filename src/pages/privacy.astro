---
// src/pages/privacy.astro
// DRAFT — plain-English Privacy Policy matching the current product
// reality. The list of data processors is authoritative: Skilly currently
// uses PostHog, OpenAI, WorkOS, Polar, Resend, and Netlify. If you add or
// remove a processor, update this page.
//
// Before any serious launch, replace with a generator-produced policy
// from Termly or iubenda and keep the processor list in sync.
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = 'April 12, 2026';

const processors = [
  {
    name: 'OpenAI',
    purpose: 'Real-time voice and vision inference — the model that powers Skilly\u2019s teaching in the macOS app',
    data: 'Transcribed audio, screen context, and model prompts, sent per teaching session. OpenAI processes these to generate responses and is contractually prohibited from using them for training.',
    location: 'United States',
    link: 'https://openai.com/policies/privacy-policy',
  },
  {
    name: 'PostHog',
    purpose: 'Anonymous product analytics + session replay on the marketing website only (page views, button clicks, scroll/cursor paths) to find and fix UX issues',
    data: 'Event names, page URLs, anonymous website session replays with all input fields automatically masked. No cookies. No persistent identifiers.',
    location: 'United States',
    link: 'https://posthog.com/privacy',
  },
  {
    name: 'WorkOS',
    purpose: 'Authentication and account management via AuthKit (handled inside the macOS app)',
    data: 'Email address, hashed password or OAuth identifier, account metadata',
    location: 'United States',
    link: 'https://workos.com/legal/privacy',
  },
  {
    name: 'Polar',
    purpose: 'Subscription billing and payment processing',
    data: 'Billing email, subscription status, payment method token (no card numbers stored by us)',
    location: 'United States',
    link: 'https://polar.sh/legal/privacy',
  },
  {
    name: 'Cloudflare',
    purpose: 'Backend infrastructure for the macOS app (API requests, edge functions, DDoS protection)',
    data: 'Server access logs, IP addresses (retained by Cloudflare\u2019s infrastructure for short periods), TLS connection metadata',
    location: 'Global CDN (varies)',
    link: 'https://www.cloudflare.com/privacypolicy/',
  },
  {
    name: 'Resend',
    purpose: 'Transactional email delivery (waitlist confirmations, account notifications)',
    data: 'Email address, message content, delivery status',
    location: 'United States',
    link: 'https://resend.com/legal/privacy-policy',
  },
  {
    name: 'Netlify',
    purpose: 'Website hosting and the backend for the waitlist form on tryskilly.app',
    data: 'Server access logs, IP addresses (retained by Netlify\u2019s infrastructure for short periods)',
    location: 'United States',
    link: 'https://www.netlify.com/privacy/',
  },
];
---
<Layout
  title="Privacy Policy — Skilly"
  description="How Skilly handles your data."
>
  <Nav />
  <main class="pt-28 lg:pt-36 pb-20 px-6">
    <article class="max-w-[720px] mx-auto">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-500 transition-colors mb-8"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 4L4 12M4 4h8M4 4v8"/>
        </svg>
        Back to tryskilly.app
      </a>

      <span class="text-[13px] font-semibold text-amber-500 tracking-[1.5px] uppercase">Legal</span>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-gray-50 mt-3 mb-4">
        Privacy Policy
      </h1>
      <p class="text-gray-500 mb-10">Last updated: {lastUpdated}</p>

      <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl px-5 py-4 mb-12">
        <p class="text-sm text-amber-300 leading-relaxed">
          <strong>Draft.</strong> This policy accurately reflects what data Skilly collects today and which third parties process it. A final, generator-produced version will replace this before we exit beta.
        </p>
      </div>

      <div class="space-y-10 text-[17px] leading-relaxed text-gray-300">
        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">1. What we collect</h2>
          <p class="mb-3">We collect the minimum needed to run Skilly:</p>
          <ul class="list-disc pl-6 space-y-1.5 marker:text-amber-500">
            <li><strong class="text-gray-50">Account data</strong> — your email address and authentication identifiers via WorkOS AuthKit</li>
            <li><strong class="text-gray-50">Billing data</strong> — subscription status, held by Polar. We never see your full card number.</li>
            <li><strong class="text-gray-50">Usage metrics</strong> — anonymous per-session numbers: session length, turn count, token counts, feature usage</li>
            <li><strong class="text-gray-50">Website analytics</strong> — anonymous page views, click events, and session replays of website visits via PostHog. Replays show scroll and cursor paths to help us find UX problems; all input fields (email, etc.) are automatically masked. No cookies. No cross-session tracking.</li>
            <li><strong class="text-gray-50">Waitlist data</strong> — if you join the waitlist, we store your email and chosen platform in our Resend audience</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">2. What we do NOT collect</h2>
          <p class="mb-3">
            To earn and keep your trust, Skilly deliberately does <strong class="text-gray-50">not</strong> store:
          </p>
          <ul class="list-disc pl-6 space-y-1.5 marker:text-amber-500">
            <li>Audio recordings of your voice</li>
            <li>Screenshots of your screen</li>
            <li>The content of your prompts or Skilly\u2019s responses</li>
            <li>Keystrokes, cursor position, or any other device telemetry from the macOS app beyond what's needed for a single live teaching session (note: the marketing website at tryskilly.app does record anonymous cursor paths via PostHog session replay to find UX issues — see "Website analytics" above)</li>
          </ul>
          <p class="mt-3">
            Audio and screen data are streamed to OpenAI for real-time processing during a teaching session and are not retained by us afterward. Only anonymous aggregate metrics about the session are kept.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">3. Third-party data processors</h2>
          <p class="mb-3">
            Skilly uses the following third-party services to run the product. Each link goes to that service's own privacy policy.
          </p>
          <div class="flex flex-col gap-3 mt-4">
            {processors.map((p) => (
              <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
                <div class="flex items-baseline justify-between gap-4 mb-2">
                  <h3 class="text-lg font-semibold text-gray-50">{p.name}</h3>
                  <a
                    href={p.link}
                    rel="noopener noreferrer"
                    target="_blank"
                    class="text-xs text-amber-500 hover:text-amber-400 underline underline-offset-2 shrink-0"
                  >
                    Privacy policy ↗
                  </a>
                </div>
                <p class="text-[15px] text-gray-400 mb-1"><strong class="text-gray-300">Purpose:</strong> {p.purpose}</p>
                <p class="text-[15px] text-gray-400 mb-1"><strong class="text-gray-300">Data shared:</strong> {p.data}</p>
                <p class="text-[15px] text-gray-400"><strong class="text-gray-300">Location:</strong> {p.location}</p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">4. Cookies and tracking</h2>
          <p>
            Skilly's website does not use cookies for analytics or tracking. PostHog is configured in anonymous/memory mode, meaning no cookies or localStorage identifiers are set. Your visit is not tied to a persistent identifier. Individual sessions are anonymous.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">5. Data retention</h2>
          <ul class="list-disc pl-6 space-y-1.5 marker:text-amber-500">
            <li>Account data is retained while your account is active and for 30 days after deletion</li>
            <li>Billing records are retained as required by applicable financial regulations (typically 7 years)</li>
            <li>Anonymous usage metrics are retained indefinitely in aggregated form, but cannot be traced back to an individual</li>
            <li>Waitlist entries are retained until launch or until you unsubscribe via the link in any email we send</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">6. Your rights</h2>
          <p class="mb-3">
            Depending on where you live, you may have rights under GDPR, CCPA, or similar laws, including:
          </p>
          <ul class="list-disc pl-6 space-y-1.5 marker:text-amber-500">
            <li>The right to access the data we hold about you</li>
            <li>The right to correct inaccurate data</li>
            <li>The right to delete your data ("right to be forgotten")</li>
            <li>The right to export your data in a portable format</li>
            <li>The right to opt out of any non-essential processing</li>
          </ul>
          <p class="mt-3">
            To exercise any of these rights, email <a href="mailto:hello@tryskilly.app" class="text-amber-500 hover:text-amber-400 underline underline-offset-2">hello@tryskilly.app</a>. We'll respond within 30 days.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">7. Children</h2>
          <p>
            Skilly is not directed at children under 13, and we do not knowingly collect data from them. If you believe we have, contact us and we'll delete it.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">8. Changes to this policy</h2>
          <p>
            We'll update this page when we add, remove, or change data processors, or when we change what we collect. Material changes will be communicated via email to your account address.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-50 mb-3">9. Contact</h2>
          <p>
            Privacy questions or requests: <a href="mailto:hello@tryskilly.app" class="text-amber-500 hover:text-amber-400 underline underline-offset-2">hello@tryskilly.app</a>.
          </p>
        </section>
      </div>

      <p class="text-sm text-gray-600 mt-16 pt-8 border-t border-gray-800">
        See also: <a href="/terms" class="text-amber-500 hover:text-amber-400 underline underline-offset-2">Terms of Service</a>
      </p>
    </article>
  </main>
  <Footer />
</Layout>
