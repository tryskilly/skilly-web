---
// src/components/Waitlist.astro
const platforms = [
  { id: 'windows', label: 'Windows' },
  { id: 'linux', label: 'Linux' },
  { id: 'ios', label: 'iOS / iPad' },
];

const platformStatus = [
  { label: 'macOS', status: 'Available now', color: 'bg-green-500' },
  { label: 'Windows', status: 'In development', color: 'bg-amber-500' },
  { label: 'Linux', status: 'Planned', color: 'bg-gray-400' },
  { label: 'iOS / iPad', status: 'Exploring', color: 'bg-gray-400' },
];
---
<section id="waitlist" class="relative py-24 lg:py-32 px-6">
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, #E5E5E0, transparent);"
  ></div>

  <div class="max-w-[560px] mx-auto text-center">
    <span class="text-[13px] font-semibold text-amber-600 tracking-[1.5px] uppercase">Coming soon</span>
    <h2 data-reveal class="reveal text-3xl sm:text-4xl lg:text-[40px] font-bold tracking-tight mt-3 mb-4 text-gray-900">
      Not on Mac yet?
    </h2>
    <p data-reveal class="reveal reveal-delay-1 text-[17px] leading-relaxed text-gray-600 mb-10">
      No worries — we're building Skilly for you too.
    </p>

    <div data-waitlist-wrapper data-reveal class="reveal reveal-delay-2 bg-white rounded-[20px] border border-gray-200 shadow-sm p-9 text-left">
      <form data-waitlist-form>
        <input type="hidden" name="platform" value="" />

        <label class="text-sm font-medium text-gray-700 block mb-2">Choose your platform</label>
        <div class="flex gap-2.5 mb-6">
          {platforms.map((p) => (
            <button
              type="button"
              data-platform={p.id}
              data-selected="false"
              class="group flex-1 flex flex-col items-center gap-2.5 px-3 py-5 rounded-xl border border-gray-300 bg-white transition-all hover:border-amber-500/50 hover:shadow-sm data-[selected=true]:border-amber-500 data-[selected=true]:bg-amber-50/60 data-[selected=true]:shadow-sm"
            >
              <!--
                Platform brand marks from Simple Icons (simpleicons.org, CC0).
                Rendered as filled paths in a 44×44 tinted square so each
                platform is instantly recognizable and visually distinct
                from the generic Lucide UI icons used elsewhere.
              -->
              <span class="w-11 h-11 rounded-xl bg-gray-100 border border-gray-200 flex items-center justify-center text-gray-600 transition-colors group-hover:bg-amber-500/10 group-hover:border-amber-500/30 group-hover:text-amber-600 group-data-[selected=true]:bg-amber-500/15 group-data-[selected=true]:border-amber-500/40 group-data-[selected=true]:text-amber-700">
                {p.id === 'windows' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M0,0H11.377V11.372H0ZM12.623,0H24V11.372H12.623ZM0,12.623H11.377V24H0Zm12.623,0H24V24H12.623" />
                  </svg>
                )}
                {p.id === 'linux' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139zm.529 3.405h.013c.213 0 .396.062.584.198.19.135.33.332.438.533.105.259.158.459.166.724 0-.02.006-.04.006-.06v.105a.086.086 0 01-.004-.021l-.004-.024a1.807 1.807 0 01-.15.706.953.953 0 01-.213.335.71.71 0 00-.088-.042c-.104-.045-.198-.064-.284-.133a1.312 1.312 0 00-.22-.066c.05-.06.146-.133.183-.198.053-.128.082-.264.088-.402v-.02a1.21 1.21 0 00-.061-.4c-.045-.134-.101-.2-.183-.333-.084-.066-.167-.132-.267-.132h-.016c-.093 0-.176.03-.262.132a.8.8 0 00-.205.334 1.18 1.18 0 00-.09.4v.019c.002.089.008.179.02.267-.193-.067-.438-.135-.607-.202a1.635 1.635 0 01-.018-.2v-.02a1.772 1.772 0 01.15-.768c.082-.22.232-.406.43-.533a.985.985 0 01.594-.2zm-2.962.059h.036c.142 0 .27.048.399.135.146.129.264.288.344.465.09.199.14.4.153.667v.004c.007.134.006.2-.002.266v.08c-.03.007-.056.018-.083.024-.152.055-.274.135-.393.2.012-.09.013-.18.003-.267v-.015c-.012-.133-.04-.2-.082-.333a.613.613 0 00-.166-.267.248.248 0 00-.183-.064h-.021c-.071.006-.13.04-.186.132a.552.552 0 00-.12.27.944.944 0 00-.023.33v.015c.012.135.037.2.08.334.046.134.098.2.166.268.01.009.02.018.034.024-.07.057-.117.07-.176.136a.304.304 0 01-.131.068 2.62 2.62 0 01-.275-.402 1.772 1.772 0 01-.155-.667 1.759 1.759 0 01.08-.668 1.43 1.43 0 01.283-.535c.128-.133.26-.2.418-.2zm1.37 1.706c.332 0 .733.065 1.216.399.293.2.523.269 1.052.468h.003c.255.136.405.266.478.399v-.131a.571.571 0 01.016.47c-.123.31-.516.643-1.063.842v.002c-.268.135-.501.333-.775.465-.276.135-.588.292-1.012.267a1.139 1.139 0 01-.448-.067 3.566 3.566 0 01-.322-.198c-.195-.135-.363-.332-.612-.465v-.005h-.005c-.4-.246-.616-.512-.686-.71-.07-.268-.005-.47.193-.6.224-.135.38-.271.483-.336.104-.074.143-.102.176-.131h.002v-.003c.169-.202.436-.47.839-.601.139-.036.294-.065.466-.065z" />
                  </svg>
                )}
                {p.id === 'ios' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701" />
                  </svg>
                )}
              </span>
              <span class="text-[13px] font-semibold text-gray-700 group-data-[selected=true]:text-amber-700">{p.label}</span>
            </button>
          ))}
        </div>

        <label class="text-sm font-medium text-gray-700 block mb-2" for="waitlist-email">Email address</label>
        <div class="flex gap-2.5">
          <input
            id="waitlist-email"
            type="email"
            name="email"
            placeholder="you@example.com"
            required
            class="flex-1 px-4 py-3 rounded-lg text-[15px] bg-white border border-gray-300 text-gray-900 placeholder-gray-400 outline-none focus:border-amber-500 transition-colors"
          />
          <button
            type="submit"
            disabled
            class="bg-amber-500 hover:bg-amber-600 text-gray-950 shadow-sm border-none rounded-lg px-6 py-3 text-[15px] font-semibold whitespace-nowrap transition-all opacity-50 cursor-not-allowed"
          >
            Join waitlist
          </button>
        </div>
        <p class="text-xs text-gray-500 mt-3">No spam. One email when your platform launches. That's it.</p>
      </form>
    </div>

    <div data-waitlist-success hidden class="bg-white rounded-[20px] border border-amber-500/30 shadow-sm p-12 text-center">
      <div class="w-14 h-14 rounded-full bg-amber-500/10 border-2 border-amber-500/25 flex items-center justify-center mx-auto mb-5">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12l5 5L20 7" />
        </svg>
      </div>
      <h3 class="text-[22px] font-semibold text-gray-900 mb-2">You're on the list!</h3>
      <p class="text-[15px] text-gray-600 leading-relaxed">
        We'll email <span data-success-email class="text-amber-700"></span> when Skilly launches on <span data-success-platform class="text-amber-700"></span>.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mt-8">
      {platformStatus.map((p) => (
        <div class="flex items-center gap-1.5">
          <span class={`block w-1.5 h-1.5 rounded-full ${p.color}`}></span>
          <span class="text-[13px] text-gray-700">{p.label}</span>
          <span class="text-[11px] text-gray-500">— {p.status}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import '../scripts/waitlist.ts';
</script>
