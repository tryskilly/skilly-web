---
// src/components/Footer.astro
import Logo from './Logo.astro';
import Wordmark from './Wordmark.astro';
import { BETA_STATUS } from '../data/config.ts';

const statusDotClass =
  BETA_STATUS === 'BETA_ACTIVE'
    ? 'bg-green-500'
    : BETA_STATUS === 'BETA_FULL'
      ? 'bg-amber-500'
      : 'bg-gray-500';
---
<footer class="border-t border-gray-200 py-12 px-6">
  <div class="max-w-site mx-auto flex flex-col gap-8">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2.5">
        <Logo size={20} variant="amber" alt="Skilly" />
        <Wordmark size="sm" />
        <span class="text-[13px] text-gray-500 ml-2">by <a href="https://moelabs.dev/" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 underline underline-offset-2 decoration-dashed decoration-gray-400 transition-colors">moelabs.dev</a></span>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a href="/terms" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Terms</a>
        <a href="/privacy" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Privacy</a>
        <span class="block w-px h-3 bg-gray-200" aria-hidden="true"></span>
        <a href="https://x.com/tryskilly" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">X / Twitter</a>
        <a href="https://github.com/tryskilly/skilly" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">GitHub</a>
        <a href="https://discord.gg/NbRVfUtwfn" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Discord</a>
      </div>
    </div>

    <div class="border-t border-gray-200/60 pt-6 flex flex-col gap-2 items-center sm:items-start">
      <p class="text-[11px] font-mono tracking-[0.08em] uppercase text-gray-500">Compare</p>
      <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-5 gap-y-2">
        <a href="/vs/cluely" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Skilly vs Cluely</a>
        <a href="/vs/rewind" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Skilly vs Rewind</a>
        <a href="/vs/raycast-ai" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Skilly vs Raycast AI</a>
        <a href="/vs/gemini-live" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Skilly vs Gemini Live</a>
        <a href="/vs/clicky" class="text-gray-600 hover:text-gray-900 text-sm transition-colors">Skilly vs Clicky</a>
        <span class="block w-px h-3 bg-gray-200" aria-hidden="true"></span>
        <a href="/vs" class="text-gray-600 hover:text-gray-900 text-sm transition-colors underline underline-offset-2 decoration-gray-300">All comparisons</a>
      </div>
    </div>

    <div class="flex justify-center sm:justify-start">
      <div
        class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full pl-2.5 pr-3 py-1"
        aria-label={`Beta program status: ${BETA_STATUS}`}
      >
        <span class={`block w-1.5 h-1.5 rounded-full ${statusDotClass} animate-pulse-soft`} aria-hidden="true"></span>
        <span class="font-mono text-[10px] font-semibold tracking-[0.1em] uppercase text-gray-600">
          Status: {BETA_STATUS}
        </span>
      </div>
    </div>
  </div>
</footer>
