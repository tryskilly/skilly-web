---
// src/pages/checkout-success.astro
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Welcome to Skilly Pro" description="Your subscription is active.">
  <Nav />
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <div class="text-5xl mb-6">
        <img src="/skilly-logo.png" alt="Skilly" class="w-16 h-16 mx-auto" onerror="this.style.display='none'" />
      </div>
      <h1 class="text-3xl font-bold text-white mb-3">You're in!</h1>
      <p class="text-zinc-400 text-lg mb-6">
        Skilly Pro is now active. You've got 3 hours of AI tutoring this month — open the app and start learning.
      </p>
      <a
        href="skilly://checkout-success"
        class="inline-block bg-amber-500 hover:bg-amber-400 text-black font-semibold px-8 py-3 rounded-full transition-colors mb-4"
      >
        Open Skilly
      </a>
      <p class="text-zinc-500 text-sm">
        Skilly should refresh your plan automatically. If it doesn't, quit and reopen the app.
      </p>
    </div>
  </main>
  <Footer />
  <script>
    // PostHog identification for the checkout success moment.
    //
    // The Cloudflare Worker's /checkout/create builds a Polar success_url
    // containing ?uid=<workos_user_id>. When Polar redirects the user here
    // after a successful subscription, we read that uid and call
    // posthog.identify() with it — using the same distinct_id the macOS app
    // uses — so this browser-side checkout moment and the app-side events
    // land on the same PostHog person profile.
    //
    // We then strip the uid from the URL via history.replaceState so the
    // WorkOS user ID never:
    //   - appears in the browser address bar beyond the first paint,
    //   - ends up in the browser history,
    //   - leaks via referrer headers on outbound links.
    //
    // Note: because Layout.astro initializes PostHog with
    // `persistence: 'memory'`, this identify call only applies to the
    // current page view. That is sufficient — the goal is to stamp this
    // single completed-purchase browser session with the real user id.
    (() => {
      const params = new URLSearchParams(window.location.search);
      const uid = params.get('uid');
      if (!uid) return;

      window.posthog?.identify(uid, {
        source: 'web_checkout',
      });
      window.posthog?.capture('web_checkout_completed', {
        source: 'web_checkout',
      });

      params.delete('uid');
      const cleanedQuery = params.toString();
      const cleanedUrl =
        window.location.pathname + (cleanedQuery ? `?${cleanedQuery}` : '') + window.location.hash;
      window.history.replaceState({}, document.title, cleanedUrl);
    })();
  </script>
</Layout>
