---
// src/components/Features.astro
//
// Modular Bento Showcase: 9 cells in an asymmetric grid that tell the
// product story. Two cells embed pixel-accurate app mockups exported
// from Pencil (Scene 2 = menu bar panel, Scene 3 = Live Tutor overlay).
//
// Alignment convention (enforced to prevent drift):
//   - Title: exactly 1 line, ellipsis if overflow (line-clamp-1)
//   - Description: exactly 2 lines, ellipsis if overflow (line-clamp-2)
//   - Text block: min-h-[72px] reserves constant vertical space so titles
//     and descriptions align across every cell regardless of content length
//   - flex-col justify-between on each cell pushes the icon to the top
//     and the text block to the bottom
//
// Icon convention: all SVGs come from Lucide (lucide.dev) with
// viewBox="0 0 24 24", stroke-width="2", round caps/joins, 20×20 display
// size (24×24 for the hero cell).
---
<section id="features" class="relative py-24 lg:py-32 px-6">
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, #E5E5E0, transparent);"
  ></div>

  <div class="max-w-site mx-auto">
    <div class="text-center mb-16 lg:mb-20 max-w-[720px] mx-auto">
      <span class="text-[13px] font-semibold text-amber-600 tracking-[1.5px] uppercase">Features</span>
      <h2 data-reveal class="reveal text-3xl sm:text-4xl lg:text-[44px] font-bold tracking-tight mt-3 mb-4 text-gray-900">
        Not a chatbot. A voice companion.
      </h2>
      <p data-reveal class="reveal reveal-delay-1 text-[17px] leading-relaxed text-gray-600">
        No typing. No chat window. Works with Figma, Excel, Blender, code editors — anything on your Mac. You talk, Skilly talks back and points at exactly what to click.
      </p>
    </div>

    <div
      data-reveal
      class="reveal reveal-delay-2 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-[220px] gap-5"
    >
      <!-- CELL 1 (2×1 hero): Cursor pointing -->
      <div class="lg:col-span-2 lg:row-span-1 bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-8 flex flex-col justify-between overflow-hidden relative">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -right-16 -bottom-16 w-60 h-60 rounded-full"
          style="background: radial-gradient(circle, rgba(245,158,11,0.12) 0%, transparent 70%);"
        ></div>
        <div class="relative w-12 h-12 rounded-[11px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4l7.07 17 2.51-7.39L21 11.07z" />
          </svg>
        </div>
        <div class="relative min-h-[82px] flex flex-col justify-end">
          <h3 class="text-[22px] sm:text-[24px] font-bold tracking-tight text-gray-900 mb-2 line-clamp-1">Cursor shows you</h3>
          <p class="text-[15px] leading-relaxed text-gray-600 line-clamp-2">Skilly's blue cursor physically moves and points to the exact button or menu, with a live transcript streaming beside it.</p>
        </div>
      </div>

      <!-- CELL 2 (2×2): Scene 2 — menu bar panel mockup -->
      <div class="lg:col-span-2 lg:row-span-2 bg-gray-100 rounded-2xl border border-gray-200 shadow-sm overflow-hidden relative flex flex-col items-center justify-between p-8 gap-6">
        <img
          src="/scenes/menu-bar-panel.png"
          alt="The Skilly menu bar panel showing the Figma Basics skill active with curriculum stage progress"
          width="320"
          class="w-full max-w-[320px] h-auto rounded-xl shadow-lg"
          loading="lazy"
        />
        <div class="text-center max-w-[260px] min-h-[66px] flex flex-col justify-end">
          <h3 class="text-lg font-bold text-gray-900 mb-1 line-clamp-1">Structured courses, your pace</h3>
          <p class="text-[13px] text-gray-600 leading-relaxed line-clamp-2">Skilly's curriculum stages advance as you learn. No quizzes, no gates.</p>
        </div>
      </div>

      <!-- CELL 3 (1×1): Multi-monitor -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-7 flex flex-col justify-between">
        <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="14" x="2" y="3" rx="2" />
            <line x1="8" x2="16" y1="21" y2="21" />
            <line x1="12" x2="12" y1="17" y2="21" />
          </svg>
        </div>
        <div class="min-h-[72px] flex flex-col justify-end">
          <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Sees what you see</h3>
          <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Skilly takes a live screenshot every time you speak — across every monitor you have.</p>
        </div>
      </div>

      <!-- CELL 4 (1×1): 16 languages / 8 voices -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-7 flex flex-col justify-between">
        <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
            <path d="M2 12h20" />
          </svg>
        </div>
        <div class="min-h-[72px] flex flex-col justify-end">
          <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Talks in your language</h3>
          <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Skilly auto-detects your spoken language and replies in the same one. 16 languages, 8 voices.</p>
        </div>
      </div>

      <!-- CELL 5 (2×1): Scene 3 — Live Tutor cursor + waveform + transcript mockup -->
      <div class="lg:col-span-2 lg:row-span-1 bg-gray-100 rounded-2xl border border-gray-200 shadow-sm overflow-hidden relative flex items-stretch">
        <div class="flex items-center gap-6 p-7 w-full">
          <img
            src="/scenes/live-tutor-overlay.png"
            alt="Skilly's cursor with a blue waveform and a floating transcript bubble showing the spoken answer"
            width="260"
            class="flex-shrink-0 w-[260px] h-auto rounded-xl shadow-md border border-gray-200"
            loading="lazy"
          />
          <div class="flex-1 min-w-0 flex flex-col justify-between self-stretch py-1">
            <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 10v3" />
                <path d="M6 6v11" />
                <path d="M10 3v18" />
                <path d="M14 8v7" />
                <path d="M18 5v13" />
                <path d="M22 10v3" />
              </svg>
            </div>
            <div class="min-h-[72px] flex flex-col justify-end">
              <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Talk out loud. Hear the answer.</h3>
              <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Skilly speaks the answer with a live transcript beside the cursor. Hands-free.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- CELL 6 (1×1): Zero retention / privacy -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-7 flex flex-col justify-between">
        <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        </div>
        <div class="min-h-[72px] flex flex-col justify-end">
          <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Zero retention</h3>
          <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Skilly streams audio and screen captures live, then they vanish. Nothing is saved.</p>
        </div>
      </div>

      <!-- CELL 7 (1×1): Push-to-talk -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-7 flex flex-col justify-between">
        <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="M6 8h.01" />
            <path d="M10 8h.01" />
            <path d="M14 8h.01" />
            <path d="M18 8h.01" />
            <path d="M8 12h.01" />
            <path d="M12 12h.01" />
            <path d="M16 12h.01" />
            <path d="M7 16h10" />
          </svg>
        </div>
        <div class="min-h-[72px] flex flex-col justify-end">
          <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Reliable push-to-talk</h3>
          <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Hold <span class="font-mono">⌃⌥</span> anywhere — reliable even in full-screen apps.</p>
        </div>
      </div>

      <!-- CELL 8 (1×1): Curriculum auto-advance -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-7 flex flex-col justify-between">
        <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
            <polyline points="16 7 22 7 22 13" />
          </svg>
        </div>
        <div class="min-h-[72px] flex flex-col justify-end">
          <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Tracks your progress</h3>
          <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Skilly auto-advances the curriculum as you complete each lesson signal.</p>
        </div>
      </div>

      <!-- CELL 9 (1×1): Auto-activates per app -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all p-7 flex flex-col justify-between">
        <div class="w-10 h-10 rounded-[9px] bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="7" height="7" x="3" y="3" rx="1" />
            <rect width="7" height="7" x="14" y="3" rx="1" />
            <rect width="7" height="7" x="14" y="14" rx="1" />
            <rect width="7" height="7" x="3" y="14" rx="1" />
          </svg>
        </div>
        <div class="min-h-[72px] flex flex-col justify-end">
          <h3 class="text-[17px] font-bold text-gray-900 mb-1 line-clamp-1">Auto-activates per app</h3>
          <p class="text-[14px] text-gray-600 leading-relaxed line-clamp-2">Switch apps and Skilly's expertise switches with you. Automatic.</p>
        </div>
      </div>
    </div>

    <!--
      Comparison table — added 2026-05-04 for GEO citability. AI systems
      (Princeton GEO study 2024) cite structured comparison tables 2.1×
      more often than equivalent prose. Targets queries like "Skilly vs
      Cluely", "Cluely alternative open source", "voice AI tutor Mac
      comparison". Visible to humans too — reads cleanly on desktop and
      degrades to vertical card list on mobile via overflow-x-auto.
    -->
    <div class="mt-20 lg:mt-24 max-w-[960px] mx-auto">
      <div class="text-center mb-8">
        <span class="text-[13px] font-semibold text-amber-600 tracking-[1.5px] uppercase">Compare</span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight mt-3 mb-3 text-gray-900">
          Skilly vs other AI assistants for Mac
        </h3>
        <p class="text-[15px] leading-relaxed text-gray-600 max-w-[640px] mx-auto">
          Honest comparison. Skilly isn't the only AI tool for Mac — but it's the only voice-first, screen-aware, open-source one that physically points at the screen.
        </p>
      </div>
      <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="w-full text-[14px] text-left">
          <thead class="bg-gray-50 text-gray-700 text-[13px] font-semibold">
            <tr>
              <th class="py-3 px-4">Feature</th>
              <th class="py-3 px-4 text-amber-700">Skilly</th>
              <th class="py-3 px-4">Cluely</th>
              <th class="py-3 px-4">ChatGPT Desktop</th>
              <th class="py-3 px-4">Rewind</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 text-gray-700">
            <tr>
              <td class="py-2.5 px-4 font-medium">Voice-first interaction</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">Yes</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-gray-500">Text-first</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Sees your screen in real time</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">Yes</td>
              <td class="py-2.5 px-4 text-emerald-600">Yes</td>
              <td class="py-2.5 px-4 text-emerald-600">Yes</td>
              <td class="py-2.5 px-4 text-emerald-600">Yes</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Moves your cursor to point</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">Yes</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Open source</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">Apache-2.0</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Native Mac app (no Electron)</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">Native Swift</td>
              <td class="py-2.5 px-4 text-gray-500">Electron</td>
              <td class="py-2.5 px-4 text-emerald-600">Native</td>
              <td class="py-2.5 px-4 text-emerald-600">Native</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Multilingual (16+ languages)</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">Yes</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-gray-500">Partial</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Pricing</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">$19/mo</td>
              <td class="py-2.5 px-4 text-gray-700">$20/mo</td>
              <td class="py-2.5 px-4 text-gray-700">$20/mo</td>
              <td class="py-2.5 px-4 text-gray-700">$9.99/mo</td>
            </tr>
            <tr>
              <td class="py-2.5 px-4 font-medium">Free trial without credit card</td>
              <td class="py-2.5 px-4 text-emerald-600 font-semibold">15 min</td>
              <td class="py-2.5 px-4 text-gray-400">No</td>
              <td class="py-2.5 px-4 text-emerald-600">Yes</td>
              <td class="py-2.5 px-4 text-emerald-600">Yes</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-[12px] text-gray-500 text-center">
        Comparisons reflect publicly-listed features as of May 2026. If anything's wrong, <a href="mailto:hello@tryskilly.app" class="underline underline-offset-2 decoration-dashed decoration-gray-400 hover:text-gray-700">tell us</a>.
      </p>
    </div>
  </div>
</section>
