---
// src/layouts/LearnLayout.astro
// Wraps base Layout.astro and injects per-article Article + optional HowTo +
// optional FAQPage + BreadcrumbList + Person schema. Used by every /learn/* page.
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { DOWNLOAD_URL } from '../data/config.ts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'learn'>;
}

const { entry } = Astro.props;
const { data, slug } = entry as any;
const articleSlug = slug ?? entry.id.replace(/\.md$/, '');

const siteUrl = 'https://tryskilly.app';
const articleUrl = `${siteUrl}/learn/${articleSlug}/`;
const ogImage = data.ogImage ?? data.heroImage ?? '/og-image.png';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.author,
  url: 'https://x.com/moelabs_dev',
  sameAs: [
    'https://x.com/moelabs_dev',
    'https://github.com/eng-mohamedszaied',
  ],
  jobTitle: 'Founder, Skilly',
  worksFor: {
    '@type': 'Organization',
    name: 'Skilly',
    url: siteUrl,
  },
};

const articleSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: data.author,
    url: 'https://x.com/moelabs_dev',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Skilly',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/skilly-mark.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
  url: articleUrl,
  image: new URL(ogImage, siteUrl).toString(),
  keywords: data.tags.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: `${siteUrl}/learn/` },
    { '@type': 'ListItem', position: 3, name: data.title, item: articleUrl },
  ],
};

const howToSchema = data.howTo
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: data.title,
      description: data.description,
      ...(data.howTo.totalTime && { totalTime: data.howTo.totalTime }),
      ...(data.howTo.tools && {
        tool: data.howTo.tools.map((name: string) => ({ '@type': 'HowToTool', name })),
      }),
      ...(data.howTo.supplies && {
        supply: data.howTo.supplies.map((name: string) => ({ '@type': 'HowToSupply', name })),
      }),
      step: data.howTo.steps.map((step: any, i: number) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: step.name,
        text: step.text,
        ...(step.image && { image: step.image }),
      })),
    }
  : null;

const faqSchema = data.faq && data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faq.map((q: { question: string; answer: string }) => ({
        '@type': 'Question',
        name: q.question,
        acceptedAnswer: { '@type': 'Answer', text: q.answer },
      })),
    }
  : null;

const formattedDate = data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  tutorial: 'Tutorial',
  'how-to': 'How-to',
  comparison: 'Comparison',
  concept: 'Concept',
  troubleshooting: 'Troubleshooting',
};
---
<Layout
  title={`${data.title} — Skilly`}
  description={data.description}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
    {howToSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(howToSchema)} />
    )}
    {faqSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <Nav />

  <main class="overflow-x-clip">
    <article class="max-w-site mx-auto px-6 pt-32 lg:pt-40 pb-16">
      <div class="max-w-[760px] mx-auto">
        <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 flex-wrap">
            <li><a href="/" class="hover:text-amber-700 transition-colors">Home</a></li>
            <li aria-hidden="true" class="text-gray-300">/</li>
            <li><a href="/learn/" class="hover:text-amber-700 transition-colors">Learn</a></li>
            <li aria-hidden="true" class="text-gray-300">/</li>
            <li class="text-gray-700 truncate max-w-[280px] sm:max-w-md">{data.title}</li>
          </ol>
        </nav>

        <header class="mb-12">
          <p class="text-[11px] font-mono tracking-[0.08em] uppercase text-amber-700 mb-4">
            {categoryLabels[data.category] ?? data.category}
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-gray-900 leading-[1.15]">
            {data.title}
          </h1>
          <p class="mt-5 text-lg leading-relaxed text-gray-600">{data.description}</p>
          <div class="mt-7 flex items-center gap-3 text-[13px] text-gray-500">
            <span>By <span class="text-gray-700 font-medium">{data.author}</span></span>
            <span aria-hidden="true" class="text-gray-300">•</span>
            <time datetime={data.pubDate.toISOString()}>{formattedDate}</time>
            {data.howTo?.totalTime && (
              <>
                <span aria-hidden="true" class="text-gray-300">•</span>
                <span>~{data.howTo.totalTime.replace('PT', '').replace('M', ' min').replace('H', ' hr ').trim()}</span>
              </>
            )}
          </div>
        </header>

        <div class="prose prose-skilly max-w-none">
          <slot />
        </div>

        {data.faq && data.faq.length > 0 && (
          <section class="mt-16 pt-10 border-t border-gray-200">
            <p class="text-[11px] font-mono tracking-[0.08em] uppercase text-gray-500 mb-4">FAQ</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-6 tracking-tight">
              Frequently asked questions
            </h2>
            <div class="flex flex-col gap-3">
              {data.faq.map((q: { question: string; answer: string }) => (
                <details class="group bg-white rounded-xl border border-gray-200 hover:border-amber-500/40 shadow-sm transition-colors">
                  <summary class="list-none cursor-pointer px-6 py-5 flex items-center justify-between gap-4 text-[16px] font-semibold text-gray-900">
                    <span>{q.question}</span>
                    <span aria-hidden="true" class="text-gray-400 text-xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
                  </summary>
                  <div class="px-6 pb-6 pt-1 text-[15px] text-gray-600 leading-relaxed">{q.answer}</div>
                </details>
              ))}
            </div>
          </section>
        )}

        <aside class="mt-16 p-8 lg:p-10 rounded-2xl bg-gradient-to-br from-amber-50 to-amber-100/40 border border-amber-200/60">
          <p class="text-[11px] font-mono tracking-[0.08em] uppercase text-amber-700 mb-3">Try Skilly</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 tracking-tight">
            A voice-first AI tutor that watches your screen.
          </h2>
          <p class="text-[15px] text-gray-700 leading-relaxed mb-6 max-w-[580px]">
            Hold Control+Option, ask out loud, and Skilly walks you through whatever app you're stuck in — Blender, Figma, Xcode, anything on Mac. 15 minutes free, no card.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href={DOWNLOAD_URL}
              data-ph-event="web_cta_download_clicked"
              data-ph-prop-location="learn_article_cta"
              class="inline-flex items-center gap-1.5 bg-amber-500 hover:bg-amber-600 text-gray-950 shadow-sm hover:shadow-md rounded-md px-5 py-2.5 text-sm font-semibold transition-all"
            >
              Download Skilly
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12L12 4M12 4H5M12 4V11"/>
              </svg>
            </a>
            <a
              href="/learn"
              class="inline-flex items-center gap-1.5 bg-white hover:bg-gray-50 text-gray-900 border border-gray-200 hover:border-gray-300 rounded-md px-5 py-2.5 text-sm font-semibold transition-all"
            >
              More articles
            </a>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
