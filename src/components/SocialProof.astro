---
// src/components/SocialProof.astro
//
// Social proof row with an integrated CTA band. Lives between the bento
// features grid and the How-It-Works section.
//
// - App icon row triggers the Availability Heuristic ("works for my case")
// - Early-access counter triggers Bandwagon / Mimetic Desire
// - Repeated CTA at a natural decision point (page-cro dimension #3)
import { DOWNLOAD_URL } from '../data/config.ts';

// No early-access users yet. Below 50, the component flips to an
// exclusivity frame ("Be one of the first to try Skilly") instead of a
// counter. Update this once the beta has real signups and the threshold
// of 50 is crossed. See docs/2026-04-16-marketing-redesign-cro-critique.md
// for why the threshold exists.
const earlyAccessCount = 0;
const showCounter = earlyAccessCount >= 50;
---
<section class="relative py-14 lg:py-20 px-6 bg-amber-50/40">
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, #FDE68A, transparent);"
  ></div>

  <div class="max-w-site mx-auto text-center">
    <p class="text-[13px] font-semibold text-amber-700 tracking-[1.5px] uppercase mb-5">
      Built for the tools you already love
    </p>

    <!--
      App logo row — real brand marks from Simple Icons (simpleicons.org, CC0).
      Muted gray-500 by default, brand color on hover (the "logo wall" treatment
      used by Linear / Vercel / Cursor). Users recognize the shapes instantly,
      and the page stays visually unified when idle.
    -->
    <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 mb-8">
      <div class="flex items-center gap-2.5 text-gray-500 hover:text-[#E87D0D] transition-colors duration-200 cursor-default" aria-label="Blender">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
