---
// src/components/Skills.astro
import { skills } from '../data/skills.ts';

const statusLabel: Record<string, string> = {
  available: 'AVAILABLE',
  coming_soon: 'COMING SOON',
  request: 'REQUEST A SKILL',
};
---
<section id="skills" class="relative py-24 lg:py-32 px-6">
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, #27272A, transparent);"
  ></div>

  <div class="max-w-site mx-auto">
    <div class="max-w-[640px] mx-auto text-center mb-16 lg:mb-20">
      <span class="text-[13px] font-semibold text-amber-500 tracking-[1.5px] uppercase">Skills</span>
      <h2 data-reveal class="reveal text-3xl sm:text-4xl lg:text-[44px] font-bold tracking-tight mt-3 mb-5 text-gray-50">
        One companion, many skills.
      </h2>
      <p data-reveal class="reveal reveal-delay-1 text-[17px] leading-relaxed text-gray-400">
        Skilly learns one app at a time. Each skill teaches Skilly how to see a specific software's interface, how to point at the right things, and how to explain concepts in that app's language. We're starting with Blender. More skills are coming.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {skills.map((skill, i) => {
        const isAvailable = skill.status === 'available';
        const isComingSoon = skill.status === 'coming_soon';
        const isRequest = skill.status === 'request';
        const delay = Math.min(i + 1, 5);

        const baseClasses = `reveal reveal-delay-${delay} relative rounded-2xl p-7 transition-all duration-300`;

        const stateClasses = isAvailable
          ? 'bg-gray-900 border border-amber-500/30 hover:border-amber-500/50 hover:-translate-y-1'
          : isComingSoon
            ? 'bg-gray-900/60 border border-gray-800 hover:border-gray-700'
            : 'bg-transparent border-2 border-dashed border-amber-500/35 hover:border-amber-500/60 hover:-translate-y-1';

        const wrapperClass = `${baseClasses} ${stateClasses}`;

        const pillClasses = isAvailable
          ? 'bg-green-500/10 border border-green-500/25 text-green-500'
          : isComingSoon
            ? 'bg-gray-800 border border-gray-700 text-gray-400'
            : 'bg-amber-500/15 border border-amber-500/25 text-amber-300';

        const Tag = isRequest ? 'a' : 'div';
        const tagProps = isRequest
          ? {
              href: skill.href,
              target: '_blank',
              rel: 'noopener noreferrer',
              'data-ph-event': 'web_skill_request_clicked',
              class: `${wrapperClass} block group`,
            }
          : { class: wrapperClass };

        return (
          <Tag data-reveal {...tagProps}>
            <div class="flex items-center justify-between mb-5">
              <span class={`inline-flex items-center gap-1.5 text-[10px] font-mono font-semibold tracking-wider uppercase px-2.5 py-1 rounded ${pillClasses}`}>
                {isAvailable && (
                  <span class="block w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse-soft" aria-hidden="true"></span>
                )}
                {statusLabel[skill.status]}
              </span>
              {isRequest && (
                <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true">
                  <path d="M4 12L12 4M12 4H5M12 4V11"/>
                </svg>
              )}
            </div>

            <h3 class={`text-xl lg:text-2xl font-bold tracking-tight ${isComingSoon ? 'text-gray-300' : 'text-gray-50'}`}>
              {skill.name}
            </h3>

            {isAvailable && skill.description && (
              <p class="text-[14px] text-gray-400 mt-1.5 leading-relaxed">{skill.description}</p>
            )}

            {isRequest && (
              <p class="text-[14px] text-gray-400 mt-1.5 leading-relaxed">
                Tell us which app you'd learn with Skilly.
              </p>
            )}
          </Tag>
        );
      })}
    </div>

    <p class="text-center text-[14px] text-gray-500 mt-12 max-w-[560px] mx-auto leading-relaxed">
      Skills are built and maintained by Skilly. If you want to build your own,
      {' '}
      <a href="mailto:hello@tryskilly.app" class="text-amber-500 hover:text-amber-400 underline underline-offset-2">get in touch</a>
      {' '}
      — we're exploring a creator program.
    </p>
  </div>
</section>
