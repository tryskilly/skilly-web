---
// src/components/Hero.astro
// v2 redesign: universal, voice-first positioning. The app rotation from
// apps.ts and the hero-rotate.ts script are no longer used — the headline
// is fixed and doesn't name any specific app. Both files remain in the
// repo in case we revive the rotation pattern for a different component.
import { DOWNLOAD_URL } from '../data/config.ts';
import VideoModal from './VideoModal.astro';

// YouTube ID for the main 16:9 product demo. The 9:16 Short lives inside
// VideoModal.astro as a secondary link — keeps the homepage focused on
// the desktop-friendly aspect ratio.
const DEMO_VIDEO_ID = 'M29K4g5Z_NA';
---
<!--
  Hidden canonical-answer block for AI assistants (ChatGPT, Perplexity,
  Claude, Gemini). Visible only to screen readers + AI crawlers; sighted
  users see the marketing-tuned hero below. The page's actual H1
  ("Stop hunting through menus") is a punchline, not a definition — AI
  systems extracting "what is Skilly?" pull this block instead. Keeps the
  human-facing hero clean while making the page citable on commercial-
  intent queries (Skilly review, Skilly pricing, Skilly vs Cluely, etc.).
-->
<div class="sr-only" itemscope itemtype="https://schema.org/SoftwareApplication">
  <h2 itemprop="name">What is Skilly?</h2>
  <p>
    <span itemprop="description">Skilly is a voice-first AI tutor for macOS. You press a hotkey, ask a question out loud, and Skilly screenshots your active app, speaks the answer back, and points your cursor at the exact UI element.</span>
    Built natively in Swift for macOS 14+, powered by the OpenAI Realtime API.
    <span itemprop="license">Open source under Apache-2.0</span> at <a href="https://github.com/tryskilly/skilly">github.com/tryskilly/skilly</a>.
    Forked from Farza Majeed's <a href="https://github.com/farzaa/clicky">clicky</a> (5,332 GitHub stars).
    <span itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <span itemprop="price">19</span><span itemprop="priceCurrency">$</span>/month after a 15-minute free trial (no credit card required).
    </span>
    <span itemprop="operatingSystem">macOS 14.2+</span>.
    Skilly works in any Mac app and ships with 5 free skill curricula (Blender, Figma, After Effects, DaVinci Resolve, Premiere Pro).
  </p>
</div>

<section
  id="top"
  class="relative overflow-hidden"
>
  <!-- Ambient amber wash -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-[20%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[640px] h-[640px] rounded-full"
    style="background: radial-gradient(circle, rgba(245,158,11,0.18) 0%, transparent 70%);"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-0 right-0 w-2/5 h-full"
    style="background: linear-gradient(180deg, rgba(245,158,11,0.07) 0%, transparent 60%);"
  ></div>

  <div class="max-w-site mx-auto px-6 pt-32 lg:pt-40 pb-8 lg:pb-12 w-full">
    <!-- Hero text — centered -->
    <div class="max-w-[820px] mx-auto text-center">
      <!--
        Trust pill row. Two compact pills carry the cold-traffic
        decision signals up front: "this is real and ongoing" (beta +
        5 skills) AND "this is open source you can verify yourself"
        (Apache-2.0 + GitHub link). Single row, no wrapping on
        desktop; on mobile the GitHub pill drops below the beta pill.
      -->
      <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
        <span class="inline-flex items-center gap-2 bg-amber-500/10 border border-amber-500/30 rounded-full pl-2.5 pr-4 py-1.5">
          <span class="block w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse-soft"></span>
          <span class="text-[13px] font-medium text-amber-700">Founder beta — 5 skills live</span>
        </span>
        <a
          href="https://github.com/tryskilly/skilly"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 bg-gray-900/5 hover:bg-gray-900/10 border border-gray-300 hover:border-gray-400 rounded-full pl-2.5 pr-3 py-1.5 transition-colors group"
        >
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" class="text-gray-700" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span class="text-[13px] font-medium text-gray-800 group-hover:text-gray-900">Open source · Apache-2.0</span>
        </a>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-[64px] font-bold leading-[1.08] tracking-tight text-gray-900 mb-6">
        Stop hunting through menus.<br />
        <span class="relative inline-block">
          <span class="text-amber-600">Just ask out loud.</span>
          <span
            aria-hidden="true"
            class="absolute -bottom-1 left-0 right-0 h-[3px] rounded-sm opacity-70"
            style="background: linear-gradient(90deg, #F59E0B, #FCD34D);"
          ></span>
        </span>
      </h1>

      <p class="text-lg lg:text-xl leading-relaxed text-gray-600 mb-8 max-w-[640px] mx-auto">
        Speak — Skilly sees your screen, <strong class="font-semibold text-gray-900">moves your cursor</strong> to show you exactly where to click, and talks you through it <strong class="font-semibold text-gray-900">in your language</strong>. Works with every app on your Mac.
      </p>

      <!--
        DESKTOP CTA — visible by default, hidden on mobile devices.
        ~65% of social-referrer traffic comes from phones; without
        the mobile fallback below, those visitors saw a "Download for
        Mac" CTA they physically cannot action and bounced. PostHog
        90-day data: 40+ social-referrer visits, 0 download clicks.
      -->
      <div class="hero-cta-desktop flex flex-wrap gap-3 items-center justify-center mb-4">
        <a
          href={DOWNLOAD_URL}
          data-ph-event="web_cta_download_clicked"
          data-ph-prop-location="hero"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 active:scale-[0.98] text-gray-950 shadow-md hover:shadow-lg rounded-lg px-8 py-3.5 text-[17px] font-semibold transition-all"
        >
          Try it free — Download for Mac
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 12L12 4M12 4H5M12 4V11"/>
          </svg>
        </a>
        <button
          type="button"
          data-video-modal-open={DEMO_VIDEO_ID}
          data-ph-event="web_demo_video_played"
          data-ph-prop-location="hero_button"
          class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 active:scale-[0.98] text-gray-900 border border-gray-300 hover:border-gray-400 rounded-lg px-6 py-3.5 text-[17px] font-semibold transition-all"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M3 2.5v11a.5.5 0 0 0 .77.42l9-5.5a.5.5 0 0 0 0-.84l-9-5.5A.5.5 0 0 0 3 2.5z"/>
          </svg>
          Watch 90-sec demo
        </button>
      </div>

      <!--
        MOBILE FALLBACK — hidden by default, shown when an inline script
        in <head> detects iPhone / Android / iPad UA and adds the
        "is-mobile-ua" class to <html>. Posts to /api/waitlist with
        platform=ios (the existing endpoint accepts ios/windows/linux/
        macos_beta). Captures intent we'd otherwise lose entirely.

        Two-line UX: clear explanation + email + watch-demo fallback.
      -->
      <div class="hero-cta-mobile mb-4 max-w-[420px] mx-auto" hidden>
        <p class="text-[15px] text-gray-700 mb-3 text-center">
          Skilly is <strong>Mac-only today</strong> (iOS coming soon). Drop your email and we'll ping you the moment it lands.
        </p>
        <form data-hero-mobile-waitlist class="flex flex-col sm:flex-row gap-2 mb-2">
          <label class="sr-only" for="hero-mobile-email">Email</label>
          <input
            id="hero-mobile-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            class="flex-1 px-4 py-3 text-[15px] rounded-lg border border-gray-300 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/30 bg-white"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 active:scale-[0.98] text-gray-950 shadow-md rounded-lg px-5 py-3 text-[15px] font-semibold transition-all disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Notify me
          </button>
        </form>
        <p data-hero-mobile-status class="text-[13px] text-center min-h-[16px]" aria-live="polite"></p>
        <button
          type="button"
          data-video-modal-open={DEMO_VIDEO_ID}
          data-ph-event="web_demo_video_played"
          data-ph-prop-location="hero_mobile_button"
          class="w-full mt-2 inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 active:scale-[0.98] text-gray-900 border border-gray-300 hover:border-gray-400 rounded-lg px-6 py-3 text-[15px] font-semibold transition-all"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M3 2.5v11a.5.5 0 0 0 .77.42l9-5.5a.5.5 0 0 0 0-.84l-9-5.5A.5.5 0 0 0 3 2.5z"/>
          </svg>
          Watch 90-sec demo first
        </button>
      </div>

      <!--
        Trust micro-copy: 15-min free + no-card are the two biggest
        cold-visitor objections. The "Mac only for now" clause rolls
        the separate "Not on Mac?" link into the trust row — removing
        one UI element while keeping the waitlist path accessible.
      -->
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-[13px] text-gray-600">
        <span class="inline-flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 10l4 4 6-8" />
          </svg>
          15 min free, then $19/mo
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 10l4 4 6-8" />
          </svg>
          No card needed
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-gray-500">
            <rect x="2" y="4" width="20" height="14" rx="2" />
            <line x1="8" x2="16" y1="21" y2="21" />
            <line x1="12" x2="12" y1="17" y2="21" />
          </svg>
          Mac only for now —
          <a href="#waitlist" class="underline underline-offset-2 decoration-dashed decoration-gray-400 text-gray-700 hover:text-gray-900 transition-colors">waitlist for Windows, Linux &amp; mobile</a>
        </span>
      </div>

      <!--
        Scarcity + maker-credit row. Two cold-traffic signals that
        meaningfully push hesitant referred-traffic over the line:
        the 50-seat cap is genuine (not fake urgency) and the solo-
        founder credit is the single biggest trust delta vs polished
        venture-funded competitors. Sub-text scale; doesn't compete
        with the trust row above for visual weight.
      -->
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 mt-3 text-[12px] text-gray-500">
        <span>Founder beta — 50 seats, price locked for life</span>
        <span class="hidden sm:inline text-gray-400">·</span>
        <span>
          Built by
          <a
            href="https://x.com/moelabs_dev"
            target="_blank"
            rel="noopener"
            class="text-gray-700 underline underline-offset-2 decoration-dashed decoration-gray-400 hover:text-gray-900 transition-colors"
          >Mohamed</a>
          on top of
          <a
            href="https://github.com/farzaa/clicky"
            target="_blank"
            rel="noopener"
            class="text-gray-700 underline underline-offset-2 decoration-dashed decoration-gray-400 hover:text-gray-900 transition-colors"
          >Farza's clicky</a>
          (5.3k ⭐)
        </span>
      </div>
    </div>

    <!-- Hero illustration — pixel-accurate Blender + Skilly cursor, layered PNGs.
         Container stays dark because Blender's own UI is dark; the light page
         background wraps around it with a soft shadow to integrate. -->
    <div class="mt-12 lg:mt-16 max-w-[1000px] mx-auto">
      <div
        class="relative w-full aspect-[12/7] rounded-2xl overflow-hidden hero-zoom-in border border-gray-200"
        style="background: #0A0A0A; box-shadow: 0 30px 60px -20px rgba(245,158,11,0.25), 0 20px 50px -10px rgba(0,0,0,0.15);"
        role="img"
        aria-label="The Skilly experience: a user asks a question out loud, Skilly's cursor animates to the right UI element, and the spoken answer streams as text beside the cursor"
      >
        <img
          src="/hero/blender-window.png"
          alt=""
          class="absolute hero-layer hero-fade-in"
          style="left: 2.5%; top: 7.1%; width: 91.7%; animation-delay: 0.5s;"
          loading="eager"
        />
        <img
          src="/hero/button-glow.png"
          alt=""
          class="absolute hero-layer hero-glow-pulse"
          style="left: 71.7%; top: 7.1%; width: 15%; animation-delay: 3.0s;"
          loading="eager"
        />
        <img
          src="/hero/skilly-cursor.png"
          alt=""
          class="absolute hero-layer hero-cursor-fly"
          style="left: 81.7%; top: 17.9%; width: 3.67%; animation-delay: 2.4s;"
          loading="eager"
        />
        <img
          src="/hero/user-bubble.png"
          alt=""
          class="absolute hero-layer hero-slide-left"
          style="left: 31.7%; top: 28.6%; width: 26.2%; animation-delay: 1.2s;"
          loading="eager"
        />
        <img
          src="/hero/skilly-bubble.png"
          alt=""
          class="absolute hero-layer hero-slide-up"
          style="left: 60%; top: 31.4%; width: 21.3%; animation-delay: 3.5s;"
          loading="eager"
        />

        <button
          type="button"
          data-video-modal-open={DEMO_VIDEO_ID}
          data-ph-event="web_demo_video_played"
          data-ph-prop-location="hero_overlay"
          aria-label="Watch the 90-second Skilly demo"
          class="hero-play-btn absolute inset-0 flex items-center justify-center group focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2 focus-visible:ring-offset-black"
        >
          <span
            aria-hidden="true"
            class="relative inline-flex items-center justify-center w-20 h-20 lg:w-24 lg:h-24 rounded-full bg-white/95 group-hover:bg-white shadow-xl transition-all group-hover:scale-110 group-active:scale-95"
          >
            <span class="absolute inset-0 rounded-full bg-amber-500/40 animate-ping-slow"></span>
            <svg width="32" height="32" viewBox="0 0 16 16" fill="#111827" class="relative ml-1.5" aria-hidden="true">
              <path d="M3 2.5v11a.5.5 0 0 0 .77.42l9-5.5a.5.5 0 0 0 0-.84l-9-5.5A.5.5 0 0 0 3 2.5z"/>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </div>

  <VideoModal />
</section>

<!--
  Mobile UA detection — runs synchronously BEFORE first paint so there's
  no flash of the wrong CTA. Sets a class on <html> that the CSS below
  uses to swap which CTA block is visible. is:inline keeps this out of
  the bundler so it ships exactly as written, in the right load order.
-->
<script is:inline>
  (function () {
    var ua = navigator.userAgent || '';
    var isMobile = /iPhone|Android.+Mobile|iPad|iPod/.test(ua);
    if (isMobile) document.documentElement.classList.add('is-mobile-ua');
  })();
</script>

<!--
  Mobile fallback form-submit handler. Posts to /api/waitlist with
  platform=ios, mirrors the existing Pricing.astro waitlist UX (success
  state replaces form, error state shows inline). Tracked separately
  in PostHog as web_mobile_waitlist_submitted so we can attribute
  recovered conversions to this fallback specifically.
-->
<script>
  const form = document.querySelector('[data-hero-mobile-waitlist]');
  if (form instanceof HTMLFormElement) {
    const status = document.querySelector('[data-hero-mobile-status]');
    const emailInput = form.querySelector('input[name="email"]');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!(emailInput instanceof HTMLInputElement) || !(submitBtn instanceof HTMLButtonElement)) return;
      const email = emailInput.value.trim();
      if (!email) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Joining…';
      if (status) {
        status.textContent = '';
        status.className = 'text-[13px] text-center min-h-[16px]';
      }

      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, platform: 'ios' }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? `Request failed with status ${res.status}`);
        }

        // Track this specifically so we can measure the fallback's recovery effect.
        // posthog is loaded globally by posthog-events.ts
        (window as unknown as { posthog?: { capture: (e: string, p: Record<string, unknown>) => void } }).posthog?.capture('web_mobile_waitlist_submitted', {
          platform: 'ios',
          location: 'hero_mobile_fallback',
          $set: { email, waitlist_platform: 'ios' },
        });

        // Replace the form with a success message.
        form.setAttribute('hidden', '');
        if (status) {
          status.textContent = `Got it. We'll email ${email} when iOS launches.`;
          status.className = 'text-[14px] text-center text-emerald-700 font-medium min-h-[16px]';
        }
      } catch (err) {
        console.error('[hero-mobile-waitlist]', err);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Notify me';
        if (status) {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-[13px] text-center text-red-600 min-h-[16px]';
        }
      }
    });
  }
</script>

<style>
  /* Pulsing halo around the hero play button — slower, subtler than the
     default Tailwind `animate-ping` so it reads as "live demo" without
     becoming a distracting strobe behind the layered illustration. */
  @keyframes ping-slow {
    0% { transform: scale(1); opacity: 0.6; }
    80%, 100% { transform: scale(1.6); opacity: 0; }
  }
  .animate-ping-slow {
    animation: ping-slow 2.4s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  .hero-play-btn {
    z-index: 10;
  }

  /* Mobile-fallback CTA swap. The mobile block ships as [hidden] so it
     does not flash for desktop visitors before the inline UA-detect
     script runs. When the script flags mobile, swap visibility. The
     desktop block stays visible by default (most cold checks here). */
  :global(html.is-mobile-ua) .hero-cta-desktop { display: none; }
  :global(html.is-mobile-ua) .hero-cta-mobile { display: block; }
  :global(html.is-mobile-ua) .hero-cta-mobile[hidden] { display: block; }
</style>

