---
// src/pages/learn/index.astro
// /learn hub — lists every published article, grouped by category.
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('learn');
const sorted = entries.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const siteUrl = 'https://tryskilly.app';

// CollectionPage schema for the hub itself.
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Skilly Learn — tutorials and guides for AI on Mac',
  description: 'Tutorials, comparisons, and how-to guides for using AI on macOS — from Blender shortcuts to OpenAI Realtime architecture.',
  url: `${siteUrl}/learn/`,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Skilly',
    url: siteUrl,
  },
  hasPart: sorted.map((entry) => ({
    '@type': 'Article',
    headline: entry.data.title,
    url: `${siteUrl}/learn/${entry.id.replace(/\.md$/, '')}/`,
    datePublished: entry.data.pubDate.toISOString(),
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: `${siteUrl}/learn/` },
  ],
};

const categories: Record<string, typeof sorted> = {};
for (const entry of sorted) {
  const cat = entry.data.category;
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(entry);
}

const categoryLabels: Record<string, string> = {
  tutorial: 'Tutorials',
  'how-to': 'How-to guides',
  comparison: 'Comparisons',
  concept: 'Concepts',
  troubleshooting: 'Troubleshooting',
};
---
<Layout
  title="Learn — tutorials and guides for AI on Mac | Skilly"
  description="Tutorials, comparisons, and how-to guides for using AI on macOS — from Blender shortcuts to OpenAI Realtime architecture."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <main class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-amber-600">Home</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-gray-700">Learn</li>
      </ol>
    </nav>

    <header class="mb-16">
      <p class="text-xs uppercase tracking-wider text-amber-600 font-semibold mb-3">Skilly Learn</p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-gray-900 leading-tight">
        Tutorials and guides for AI on your Mac.
      </h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-2xl">
        Hands-on walkthroughs, honest comparisons, and the occasional deep dive into how voice + screen-aware AI actually works on macOS.
      </p>
    </header>

    {sorted.length === 0 ? (
      <p class="text-gray-500">No articles yet. Check back soon.</p>
    ) : (
      <div class="flex flex-col gap-16">
        {Object.entries(categories).map(([cat, items]) => (
          <section>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              {categoryLabels[cat] ?? cat}
            </h2>
            <div class="grid gap-4 md:grid-cols-2">
              {items.map((entry) => {
                const slug = entry.id.replace(/\.md$/, '');
                return (
                  <a
                    href={`/learn/${slug}/`}
                    class="group p-6 rounded-2xl bg-white border border-gray-200 hover:border-amber-500/60 shadow-sm hover:shadow-md transition-all"
                  >
                    <h3 class="text-xl font-semibold text-gray-900 group-hover:text-amber-700 transition-colors leading-snug">
                      {entry.data.title}
                    </h3>
                    <p class="mt-2 text-gray-600 leading-relaxed text-sm">{entry.data.description}</p>
                    <p class="mt-4 text-xs text-gray-500">
                      <time datetime={entry.data.pubDate.toISOString()}>
                        {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                      </time>
                    </p>
                  </a>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}
  </main>
</Layout>
